{
  "id": "conf-quorum-not-met",
  "schema_version": "0.1",
  "claim": {
    "statement": "A quorum cannot certify when one required member refuses upstream.",
    "kind": "impossibility",
    "negation_of": "a quorum result where a lying or refused member still satisfies the threshold",
