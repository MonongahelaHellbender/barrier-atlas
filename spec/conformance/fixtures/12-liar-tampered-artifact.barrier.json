{
  "id": "conf-liar-tampered-artifact",
  "schema_version": "0.1",
  "claim": {
    "statement": "A lying plugin cannot certify when the declared artifact hash mismatches.",
    "kind": "impossibility",
    "negation_of": "certification of a tampered artifact by a malicious checker",
